{
  "tsconfig": "tsconfig.packages.json",
  "include": [
    "packages/**/src/*.ts",
    "packages/**/src/**/*.ts"
  ],
  "exclude": [
    "**/node_modules/**",
    "packages/tools/**",
    "packages/atom/svelte/src/**",
    "packages/**/src/index.ts",
    "packages/**/src/*Generated.ts",
    "packages/**/src/internal/**",
    "packages/**/src/**/internal/**"
  ],
  "output": ".data/jsdocs.json"
}
