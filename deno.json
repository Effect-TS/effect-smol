{
    "nodeModulesDir": "manual",
    "unstable": [
        "sloppy-imports"
    ],
    "compilerOptions": {
        "strict": true,
        "exactOptionalPropertyTypes": true,
        "lib": [
            "ESNext",
            "DOM",
            "DOM.Iterable"
        ],
        "types": [
            "npm:@types/node"
        ],
        "noImplicitReturns": false,
        "noUnusedLocals": true,
        "noUnusedParameters": false,
        "noImplicitOverride": false,
        "noFallthroughCasesInSwitch": true,
        "noErrorTruncation": false,
        "noImplicitAny": true,
        "noImplicitThis": true,
        "noUncheckedIndexedAccess": false,
        "strictNullChecks": true
    },
    "imports": {
        "effect": "./packages/effect/src/index.ts",
        "effect/": "./packages/effect/src/",
        "#dist/": "./dist/dist/esm/"
    },
    "exclude": [
        "**/node_modules/",
        "**/build/",
        "**/dist/",
        "**/bundle/",
        "scratchpad/",
        "scripts/",
        "vitest.setup.ts"
    ]
}
