{
    "nodeModulesDir": "manual",
    "unstable": [
        "sloppy-imports"
    ],
    "compilerOptions": {
        "strict": true,
        "exactOptionalPropertyTypes": true,
        "lib": [
            "ES2022",
            "DOM",
            "DOM.Iterable"
        ],
        "types": [
            "npm:@types/node"
        ],
        "noImplicitReturns": false,
        "noUnusedLocals": true,
        "noUnusedParameters": false,
        "noImplicitOverride": false,
        "noFallthroughCasesInSwitch": true,
        "noErrorTruncation": false,
        "noImplicitAny": true,
        "noImplicitThis": true,
        "noUncheckedIndexedAccess": false,
        "strictNullChecks": true
    },
    "exclude": [
        "**/node_modules/",
        "**/build/",
        "**/dist/",
        "**/bundle/",
        "scratchpad/",
        "scripts/",
        "vitest.setup.ts",
        "packages/effect/test/Schema.test.ts",
        "packages/effect/test/SchemaToSerializer.test.ts"
    ]
}
